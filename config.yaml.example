# Nano-Claw Configuration
# This file is loaded by src/config.py
# Environment variables can override these values

llm:
  provider: custom  # openai, azure, ollama, custom
  model: your-model-name
  base_url: https://api.example.com/v1
  # context_window: 128000  # Optional: model context window size in tokens

logging:
  enabled: true
  async_mode: false
  log_dir: ~/.babyclaw/sessions
  buffer_size: 1

agent:
  max_iterations: 10

ui:
  enable_streaming: true
  loading_indicator_interval: 0.8
  live_activity_mode: simple
  live_activity_details: collapsed

server:
  host: 127.0.0.1
  port: 8765
  db_path: ~/.babyclaw/state.db
  max_parallel_runs: 1
  serve_ui: true
  sse_heartbeat_seconds: 10

context:
  auto_compact: true  # Automatically compact when estimated context usage crosses the threshold below.
  auto_compact_threshold: 0.85  # Start compaction when estimated baseline usage reaches 85% of the model context window.
  target_usage_after_compaction: 0.60  # Try to reduce estimated baseline usage to about 60% after compaction completes.
  min_recent_turns: 6  # Always keep at least this many most-recent complete turns as raw transcript after compaction.

subagents:
  enabled: true
  max_parallel: 3
  max_per_turn: 6
  default_timeout_seconds: 180

plan:
  enabled: true
  plan_dir: .babyclaw/plans
  allow_subagents: true

memory:
  enabled: true
  root_dir: ~/.babyclaw/sessions
  debug: false
  auto_load_memory: true
  max_auto_chars: 4000
  max_search_results: 10
  default_read_policy: curated_plus_recent_daily
  default_prompt_policy: curated_plus_recent_daily
  recent_daily_days: 2
  max_auto_curated_hits: 3
  max_auto_daily_hits: 2

macos_tools:
  enabled: true
  timeout_seconds: 10
  enable_finder: true
  enable_calendar: true
  enable_notes: true
  enable_reminders: true
  enable_messages: true

web_tools:
  enabled: true
  timeout_seconds: 15
  max_response_bytes: 2000000
  max_content_chars: 20000
  allow_private_networks: false
  enable_fetch_url: true
  enable_read_webpage: true
  enable_extract_page_links: true

extensions:
  enabled: true
  user_root: ~/.babyclaw/extensions
  repo_root: .babyclaw/extensions
  runner_timeout_seconds: 60
  install_timeout_seconds: 30
  catalogs: []

# MCP (Model Context Protocol) Servers
# External tool servers that babyclaw can connect to
mcp:
  servers:
    - name: deepwiki
      url: https://mcp.deepwiki.com/mcp  # DeepWiki MCP endpoint; do not append /tools
      enabled: true
      timeout: 30
    - name: example-server
      url: http://localhost:3000
      enabled: false  # Disabled by default, enable when you have an MCP server running
      timeout: 30
    # Add more MCP servers here:
    # - name: database
    #   url: http://localhost:3001
    #   enabled: true
